{
  "name": "meeting-notes",
  "version": "0.1.4",
  "description": "Obsidian plugin for transcribing existing meeting recordings with OpenAI.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "transcription",
    "meeting-notes"
  ],
  "license": "MIT",
  "devDependencies": {
    "builtin-modules": "^3.3.0",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.8.3"
  }
}
